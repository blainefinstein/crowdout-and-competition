nudge_x = 0.12,
size = 3.6,
color = "#9C3D00",
fontface = "bold"
) +
annotate(
"text",
x = max(competition_gap_band$competition_mean, na.rm = TRUE) - 0.15,
y = max(competition_gap_band$`Control municipalities`, na.rm = TRUE) + 150,
label = "Higher competition narrows\nthe spending gap",
hjust = 1,
vjust = 1,
size = 3.8,
fontface = "bold",
color = "#1D3557"
) +
scale_color_manual(
values = c(
"Control municipalities" = "#2C7BB6",
"KALAHI municipalities" = "#D7191C"
)
) +
labs(
x = "Political competition (z-score; higher = more competitive)",
y = "Mean per capita public service spending (PhP)",
title = "Figure 3a: Competition compresses the treated-control spending gap",
subtitle = "Municipalities grouped into competition bins; shaded area marks the spending gap between treated and control municipalities",
color = NULL
) +
theme_minimal(base_size = 12) +
theme(
plot.title = element_text(face = "bold"),
plot.subtitle = element_text(size = 10),
legend.position = "bottom",
panel.grid.minor = element_blank()
)
competition_gap_plot <- dat |>
filter(!is.na(competition_z), !is.na(kalahi_spending_percap)) |>
mutate(
comp_bin = ntile(competition_z, 12),
treat_label = if_else(treat == 1, "KALAHI municipalities", "Control municipalities")
) |>
group_by(comp_bin, treat_label) |>
summarise(
spending_mean = mean(kalahi_spending_percap, na.rm = TRUE),
.groups = "drop"
)
competition_bin_centers <- dat |>
filter(!is.na(competition_z), !is.na(kalahi_spending_percap)) |>
mutate(comp_bin = ntile(competition_z, 12)) |>
group_by(comp_bin) |>
summarise(
competition_mean = mean(competition_z, na.rm = TRUE),
.groups = "drop"
)
competition_gap_plot <- competition_gap_plot |>
left_join(competition_bin_centers, by = "comp_bin")
competition_gap_band <- competition_gap_plot |>
select(comp_bin, competition_mean, treat_label, spending_mean) |>
pivot_wider(names_from = treat_label, values_from = spending_mean) |>
arrange(competition_mean) |>
mutate(
gap = `Control municipalities` - `KALAHI municipalities`
)
gap_peak <- competition_gap_band |>
filter(!is.na(gap)) |>
slice_max(gap, n = 1, with_ties = FALSE)
ggplot() +
geom_ribbon(
data = competition_gap_band,
aes(
x = competition_mean,
ymin = `KALAHI municipalities`,
ymax = `Control municipalities`
),
fill = "#F4A261",
alpha = 0.28
) +
geom_line(
data = competition_gap_plot,
aes(x = competition_mean, y = spending_mean, color = treat_label),
linewidth = 1.4
) +
geom_point(
data = competition_gap_plot,
aes(x = competition_mean, y = spending_mean, color = treat_label),
size = 2.4
) +
geom_text(
data = gap_peak,
aes(
x = competition_mean,
y = (`Control municipalities` + `KALAHI municipalities`) / 2,
label = "Largest treatment gap"
),
nudge_x = 0.12,
size = 3.6,
color = "#9C3D00",
fontface = "bold"
) +
annotate(
"text",
x = max(competition_gap_band$competition_mean, na.rm = TRUE) - 0.15,
y = max(competition_gap_band$`Control municipalities`, na.rm = TRUE) + 150,
label = "Higher competition narrows\nthe spending gap",
hjust = 1,
vjust = 1,
size = 3.8,
fontface = "bold",
color = "#1D3557"
) +
scale_color_manual(
values = c(
"Control municipalities" = "#2C7BB6",
"KALAHI municipalities" = "#D7191C"
)
) +
labs(
x = "Political competition (z-score; higher = more competitive)",
y = "Mean per capita public service spending (PhP)",
title = "Figure 3a: Competition compresses the treated-control spending gap",
subtitle = "Municipalities grouped into competition bins; shaded area marks the spending gap between treated and control municipalities",
color = NULL
) +
theme_minimal(base_size = 12) +
theme(
plot.title = element_text(face = "bold"),
plot.subtitle = element_text(size = 10),
legend.position = "bottom",
panel.grid.minor = element_blank()
)
