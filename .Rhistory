# Read in welfare data
welfare_dat <- read_csv("Data/derived/welfare_data.csv", show_col_types = FALSE)
# Welfare DiD model
welfare_did <- feols(
infra_access ~ treat * post_2013 +
log(pop07nso) + pi + land + bgytot + dynasty_next_mayor + vote_diff |
pairnum + post_2013,
cluster = ~mun_psgc,
data = welfare_dat
)
# Present results
modelsummary(list("Infrastructure" = welfare_did),
coef_map = c(
"treat" = "treat",
"post_2013" = "post-2013",
"treat:post_2013" = "treat * post-2013"
),
stars = T,
title = "Crowd-out attenuates impact of aid",
output = "kableExtra") |>
kable_classic(latex_options = "hold_position") |>
kable_styling(full_width = FALSE, position = "center") |>
footnote(general = "Infrastructure outcomes in standard units. Population covariate scaled per 1,000 people
such that significant digits are visible in the parameter estimate.", threeparttable = TRUE, escape = FALSE, footnote_as_chunk = TRUE)
welfare_did <- feols(
infra_access ~ treat : post_2013 +
log(pop07nso) + pi + land + bgytot + dynasty_next_mayor + vote_diff |
pairnum + post_2013,
cluster = ~mun_psgc,
data = welfare_dat
)
# Present results
modelsummary(list("Infrastructure" = welfare_did),
coef_map = c(
"treat" = "treat",
"post_2013" = "post-2013",
"treat:post_2013" = "treat * post-2013"
),
stars = T,
title = "Crowd-out attenuates impact of aid",
output = "kableExtra") |>
kable_classic(latex_options = "hold_position") |>
kable_styling(full_width = FALSE, position = "center") |>
footnote(general = "Infrastructure outcomes in standard units. Population covariate scaled per 1,000 people
such that significant digits are visible in the parameter estimate.", threeparttable = TRUE, escape = FALSE, footnote_as_chunk = TRUE)
welfare_did <- feols(
infra_access ~ treat * post_2013 +
log(pop07nso) + pi + land + bgytot + dynasty_next_mayor + vote_diff |
pairnum,
cluster = ~mun_psgc,
data = welfare_dat
)
# Present results
modelsummary(list("Infrastructure" = welfare_did),
coef_map = c(
"treat" = "treat",
"post_2013" = "post-2013",
"treat:post_2013" = "treat * post-2013"
),
stars = T,
title = "Crowd-out attenuates impact of aid",
output = "kableExtra") |>
kable_classic(latex_options = "hold_position") |>
kable_styling(full_width = FALSE, position = "center") |>
footnote(general = "Infrastructure outcomes in standard units. Population covariate scaled per 1,000 people
such that significant digits are visible in the parameter estimate.", threeparttable = TRUE, escape = FALSE, footnote_as_chunk = TRUE)
# Smoothed companion figure for pre-treatment trends
historic_smooth <- historic_dat |>
mutate(
year_num = as.numeric(year),
spend_pc = total_spending / pop07nso,
historic_date = as.Date(sprintf("%d-01-01", as.integer(year_num))),
treat = factor(ifelse(treat == 1, "KALAHI municipalities", "Control municipalities"))
) |>
filter(
year_num >= 2007,
year_num <= 2015,
is.finite(spend_pc)
)
historic_smooth |>
ggplot(aes(x = historic_date, y = spend_pc, color = treat, fill = treat)) +
geom_smooth(method = "loess", se = TRUE, linewidth = 1.2, span = 0.9, alpha = 0.16) +
geom_vline(xintercept = as.Date("2011-01-01"), linetype = "dashed", color = "gray50", linewidth = 0.9) +
scale_color_manual(values = c("#2C7BB6", "#D7191C")) +
scale_fill_manual(values = c(alpha("#2C7BB6", 0.2), alpha("#D7191C", 0.2))) +
scale_y_continuous(labels = label_comma()) +
scale_x_date(
breaks = as.Date(sprintf("%d-01-01", 2007:2015)),
limits = as.Date(c("2007-01-01", "2015-12-31")),
date_labels = "%Y"
) +
labs(
x = "Year",
y = "Per capita spending (PhP)",
title = "Figure 2A: Smoothed trends in municipal spending: KALAHI vs control municipalities",
subtitle = "LOESS-smoothed municipal spending per capita, 2007–2015; dashed line indicates program rollout",
color = NULL,
fill = NULL,
caption = "Notes: Curves are LOESS smooths of municipality-year spending observations from Bureau of Local Government Finance data."
) +
theme_minimal(base_size = 12) +
theme(
plot.title = element_text(face = "bold"),
plot.subtitle = element_text(size = 10),
legend.position = "bottom",
panel.grid.minor = element_blank()
)
