family_plot_results <- bind_rows(lapply(unique(family_plot_dat$family), function(nm) {
m <- feols(
y ~ treat * mayoral_discretion_index +
baseline + log(pop07nso) + pi + land + bgytot + vote_diff + dynasty_next_mayor |
pairnum + sample,
cluster = ~mun_psgc,
data = family_plot_dat |> filter(family == nm)
)
ct <- coeftable(m)
tibble(
family = nm,
estimate = ct["treat:mayoral_discretion_index", "Estimate"],
se = ct["treat:mayoral_discretion_index", "Std. Error"],
p = ct["treat:mayoral_discretion_index", "Pr(>|t|)"]
)
})) |>
mutate(
ci_low = estimate - 1.96 * se,
ci_high = estimate + 1.96 * se,
p_label = sprintf("p = %.3f", p),
family = factor(
family,
levels = c(
"Official assistance",
"Community support and trust",
"Economic welfare",
"Service access"
)
)
)
xmin_main <- min(family_plot_results$ci_low, na.rm = TRUE)
xmax_main <- max(family_plot_results$ci_high, na.rm = TRUE)
xrange_main <- xmax_main - xmin_main
family_plot_results |>
mutate(p_x = xmin_main - 0.18 * xrange_main) |>
ggplot(aes(x = estimate, y = family)) +
geom_vline(xintercept = 0, linetype = "dashed", color = "gray55") +
geom_errorbarh(aes(xmin = ci_low, xmax = ci_high), height = 0.18, color = "gray35") +
geom_point(
aes(color = p < 0.05),
size = 2.8,
show.legend = FALSE
) +
geom_text(aes(x = p_x, label = p_label), hjust = 0, size = 3.3, color = "gray20") +
scale_color_manual(values = c(`TRUE` = "#8C2F39", `FALSE` = "#7A7A7A")) +
coord_cartesian(xlim = c(xmin_main - 0.26 * xrange_main, xmax_main + 0.05 * xrange_main)) +
labs(
x = "Change in Kalahi treatment effect per 1 SD increase in mayoral discretion",
y = NULL,
title = "Figure 6: Welfare gains contract where mayors have greater discretion",
subtitle = "Wave-standardized family indices pooled across midline and endline with matched-pair and wave fixed effects"
) +
theme_minimal(base_size = 12) +
theme(
panel.grid.minor = element_blank(),
axis.text.y = element_text(hjust = 1)
)
