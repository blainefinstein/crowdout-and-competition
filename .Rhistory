make_domain_mt <- function(df, vars, treat_var = "treat") {
out <- df
zvars <- c()
for (v in vars) {
zv <- paste0("z_", v)
out[[zv]] <- z_from_control_mt(out[[v]], out[[treat_var]])
zvars <- c(zvars, zv)
}
out$domain_index <- rowMeans(out[, zvars], na.rm = TRUE)
out$domain_index[!is.finite(out$domain_index)] <- NA_real_
out
}
mid_extra_main <- read_dta(
"Data/KALAHI/Interim Public Use Data Package (3)/Data/Additional_Propositions_INT_A.dta"
) |>
as_tibble() |>
group_by(lk4, hh_id_psgc) |>
summarise(across(everything(), first_nonmissing_mt), .groups = "drop")
mayoral_discretion_main <- dat |>
group_by(region, province, mun, mun_psgc, pairnum) |>
summarise(
fiscal_slack_index = first_nonmissing_mt(fiscal_slack_index),
government_employment_share_z = first_nonmissing_mt(government_employment_share_z),
debt_share_z = first_nonmissing_mt(debt_share_z),
.groups = "drop"
) |>
mutate(
payroll_debt_index = rowMeans(cbind(government_employment_share_z, debt_share_z), na.rm = TRUE),
fiscal_slack_index = std_mt(fiscal_slack_index),
payroll_debt_index = std_mt(payroll_debt_index),
mayoral_discretion_index = std_mt(
rowMeans(cbind(fiscal_slack_index, payroll_debt_index), na.rm = TRUE)
)
) |>
select(region, province, mun, mun_psgc, pairnum, mayoral_discretion_index)
welfare_main_base <- read_csv("Data/derived/welfare_data.csv", show_col_types = FALSE) |>
left_join(
mayoral_discretion_main,
by = c("region", "province", "mun", "mun_psgc", "pairnum"),
relationship = "many-to-one"
) |>
filter(!is.na(mayoral_discretion_index), !is.na(pairnum), !is.na(mun_psgc))
welfare_main_mid <- welfare_main_base |>
filter(post_2013 == 0) |>
left_join(
mid_extra_main |>
select(lk4, hh_id_psgc, starts_with("de"), starts_with("sct")),
by = c("lk4", "hh_id_psgc"),
relationship = "many-to-one"
) |>
mutate(
no_yolanda_hardship = clean_yesno_12_mt(de6a),
sick_neighbors = clean_binary01_mt(sct5_2),
sick_leaders = clean_binary01_mt(sct5_3),
sick_health = clean_binary01_mt(sct5o6),
sick_clinic = clean_binary01_mt(sct5o7),
sick_family = clean_binary01_mt(sct5o12),
sick_friends = clean_binary01_mt(sct5o15),
sick_noone = 1 - clean_binary01_mt(sct5o1),
trust_inside = rev_trust_mt(sct8a),
trust_outside = rev_trust_mt(sct8b)
)
welfare_main_end <- welfare_main_base |>
filter(post_2013 == 1)
family_plot_dat <- bind_rows(
welfare_main_mid |>
make_domain_mt(c("trust_inside", "trust_outside")) |>
filter(!is.na(domain_index), !is.na(pretreat_welfare)) |>
transmute(
family = "Social cohesion",
y = domain_index,
baseline = pretreat_welfare,
sample = "Midline",
treat, mayoral_discretion_index, pop07nso, pi, land, bgytot,
vote_diff, dynasty_next_mayor, pairnum, mun_psgc
),
welfare_main_end |>
filter(!is.na(domain_hardship_support), !is.na(pretreat_welfare)) |>
transmute(
family = "Social cohesion",
y = domain_hardship_support,
baseline = pretreat_welfare,
sample = "Endline",
treat, mayoral_discretion_index, pop07nso, pi, land, bgytot,
vote_diff, dynasty_next_mayor, pairnum, mun_psgc
),
welfare_main_mid |>
make_domain_mt(c("sick_neighbors", "sick_leaders", "sick_health", "sick_clinic", "sick_family", "sick_friends", "sick_noone")) |>
filter(!is.na(domain_index), !is.na(pretreat_welfare)) |>
transmute(
family = "Discretionary support",
y = domain_index,
baseline = pretreat_welfare,
sample = "Midline",
treat, mayoral_discretion_index, pop07nso, pi, land, bgytot,
vote_diff, dynasty_next_mayor, pairnum, mun_psgc
),
welfare_main_end |>
filter(!is.na(domain_hardship_support), !is.na(pretreat_welfare)) |>
transmute(
family = "Discretionary support",
y = domain_hardship_support,
baseline = pretreat_welfare,
sample = "Endline",
treat, mayoral_discretion_index, pop07nso, pi, land, bgytot,
vote_diff, dynasty_next_mayor, pairnum, mun_psgc
),
welfare_main_mid |>
filter(!is.na(infra_access), !is.na(pretreat_infra_access)) |>
transmute(
family = "Service access",
y = infra_access,
baseline = pretreat_infra_access,
sample = "Midline",
treat, mayoral_discretion_index, pop07nso, pi, land, bgytot,
vote_diff, dynasty_next_mayor, pairnum, mun_psgc
),
welfare_main_end |>
filter(!is.na(domain_water_access), !is.na(pretreat_welfare)) |>
transmute(
family = "Service access",
y = domain_water_access,
baseline = pretreat_welfare,
sample = "Endline",
treat, mayoral_discretion_index, pop07nso, pi, land, bgytot,
vote_diff, dynasty_next_mayor, pairnum, mun_psgc
),
welfare_main_mid |>
filter(!is.na(no_yolanda_hardship), !is.na(pretreat_welfare)) |>
transmute(
family = "Household welfare",
y = no_yolanda_hardship,
baseline = pretreat_welfare,
sample = "Midline",
treat, mayoral_discretion_index, pop07nso, pi, land, bgytot,
vote_diff, dynasty_next_mayor, pairnum, mun_psgc
),
welfare_main_end |>
filter(!is.na(domain_household_spending), !is.na(pretreat_welfare)) |>
transmute(
family = "Household welfare",
y = domain_household_spending,
baseline = pretreat_welfare,
sample = "Endline",
treat, mayoral_discretion_index, pop07nso, pi, land, bgytot,
vote_diff, dynasty_next_mayor, pairnum, mun_psgc
)
)
family_plot_models <- list(
"Social cohesion" = family_plot_dat |> filter(family == "Social cohesion"),
"Discretionary support" = family_plot_dat |> filter(family == "Discretionary support"),
"Service access" = family_plot_dat |> filter(family == "Service access"),
"Household welfare" = family_plot_dat |> filter(family == "Household welfare")
)
family_plot_results <- bind_rows(lapply(names(family_plot_models), function(nm) {
m <- feols(
y ~ treat * mayoral_discretion_index +
baseline + log(pop07nso) + pi + land + bgytot + vote_diff + dynasty_next_mayor |
pairnum + sample,
cluster = ~mun_psgc,
data = family_plot_models[[nm]]
)
ct <- coeftable(m)
tibble(
family = nm,
estimate = ct["treat:mayoral_discretion_index", "Estimate"],
se = ct["treat:mayoral_discretion_index", "Std. Error"],
p = ct["treat:mayoral_discretion_index", "Pr(>|t|)"]
)
})) |>
mutate(
ci_low = estimate - 1.96 * se,
ci_high = estimate + 1.96 * se,
p_label = sprintf("p = %.3f", p)
) |>
arrange(estimate) |>
mutate(family = factor(family, levels = family))
xmin_main <- min(family_plot_results$ci_low, na.rm = TRUE)
xmax_main <- max(family_plot_results$ci_high, na.rm = TRUE)
xrange_main <- xmax_main - xmin_main
family_plot_results |>
mutate(p_x = xmin_main - 0.18 * xrange_main) |>
ggplot(aes(x = estimate, y = family)) +
geom_vline(xintercept = 0, linetype = "dashed", color = "gray55") +
geom_errorbarh(aes(xmin = ci_low, xmax = ci_high), height = 0.18, color = "gray35") +
geom_point(size = 2.8, color = "#8C2F39") +
geom_text(aes(x = p_x, label = p_label), hjust = 0, size = 3.3, color = "gray20") +
coord_cartesian(xlim = c(xmin_main - 0.26 * xrange_main, xmax_main + 0.05 * xrange_main)) +
labs(
x = "Coefficient on Treat x mayoral discretion",
y = NULL,
title = "Figure 6: Welfare gains contract as mayoral discretion rises",
subtitle = "Pooled midline-endline family indices with matched-pair and wave fixed effects"
) +
theme_minimal(base_size = 12) +
theme(
panel.grid.minor = element_blank(),
axis.text.y = element_text(hjust = 1)
)
# Main-text redesign: pooled welfare-family moderation figure
clean_num_mt <- function(x) {
y <- as.numeric(x)
y[y < 0] <- NA_real_
y
}
clean_yesno_12_mt <- function(x) {
y <- clean_num_mt(x)
case_when(
y == 1 ~ 0,
y == 2 ~ 1,
TRUE ~ NA_real_
)
}
clean_binary01_mt <- function(x) {
y <- clean_num_mt(x)
case_when(
y == 1 ~ 1,
y == 0 ~ 0,
TRUE ~ NA_real_
)
}
rev_trust_mt <- function(x) {
y <- clean_num_mt(x)
case_when(
y %in% 1:5 ~ 6 - y,
TRUE ~ NA_real_
)
}
first_nonmissing_mt <- function(x) {
y <- x[!is.na(x)]
if (length(y) == 0) {
return(NA)
}
y[1]
}
std_mt <- function(x) {
mu <- mean(x, na.rm = TRUE)
sigma <- sd(x, na.rm = TRUE)
if (is.na(sigma) || sigma == 0) {
return(rep(NA_real_, length(x)))
}
(x - mu) / sigma
}
z_from_control_mt <- function(x, treat) {
mu <- mean(x[treat == 0], na.rm = TRUE)
sigma <- sd(x[treat == 0], na.rm = TRUE)
if (is.na(sigma) || sigma == 0) {
return(rep(NA_real_, length(x)))
}
(x - mu) / sigma
}
make_domain_mt <- function(df, vars, treat_var = "treat") {
out <- df
zvars <- c()
for (v in vars) {
zv <- paste0("z_", v)
out[[zv]] <- z_from_control_mt(out[[v]], out[[treat_var]])
zvars <- c(zvars, zv)
}
out$domain_index <- rowMeans(out[, zvars], na.rm = TRUE)
out$domain_index[!is.finite(out$domain_index)] <- NA_real_
out
}
